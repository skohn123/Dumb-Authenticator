<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.DumbAuthenticator" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/bg_root</item>
        <item name="android:colorBackground">@color/bg_root</item>
        <item name="android:statusBarColor">@color/bg_root</item>
        <item name="android:navigationBarColor">@color/bg_root</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:colorAccent">@color/accent_green</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Widget.DA.TopBar.Title" parent="">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">@color/accent_green</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="Widget.DA.SectionLabel" parent="">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:letterSpacing">0.25</item>
    </style>

    <style name="Widget.DA.Button.Primary" parent="">
        <item name="android:background">@drawable/btn_primary_bg</item>
        <item name="android:textColor">@color/bg_root</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="Widget.DA.Button.Secondary" parent="">
        <item name="android:background">@drawable/btn_secondary_bg</item>
        <item name="android:textColor">@color/accent_green</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="Widget.DA.Button.Ghost" parent="">
        <item name="android:background">@drawable/btn_ghost_bg</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">12sp</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="Widget.DA.IconButton" parent="">
        <item name="android:background">@drawable/btn_icon_bg</item>
        <item name="android:textColor">@color/accent_green</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">18sp</item>
        <item name="android:gravity">center</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="Widget.DA.EditText" parent="">
        <item name="android:background">@drawable/edit_bg</item>
        <item name="android:textColor">@color/accent_green</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">14sp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
    </style>

    <style name="Theme.DA.Dialog" parent="android:Theme.Material.Dialog.Alert">
        <item name="android:windowBackground">@drawable/dialog_bg</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:colorAccent">@color/accent_green</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:buttonBarPositiveButtonStyle">@style/Widget.DA.Dialog.Button</item>
        <item name="android:buttonBarNegativeButtonStyle">@style/Widget.DA.Dialog.Button</item>
        <item name="android:buttonBarNeutralButtonStyle">@style/Widget.DA.Dialog.Button</item>
    </style>

    <style name="Widget.DA.Dialog.Button" parent="android:Widget.Material.Button.Borderless">
        <item name="android:textColor">@color/accent_green</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:focusable">true</item>
    </style>
</resources>
